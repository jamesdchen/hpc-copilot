{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/best_submit_window.output.json",
  "title": "best-submit-window output data",
  "description": "Top-k submit-time candidates in ascending predicted-wait order.",
  "type": "object",
  "required": [
    "profile",
    "cluster",
    "within_hours",
    "top_k",
    "candidates"
  ],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "title": "Profile",
      "type": "string"
    },
    "cluster": {
      "title": "Cluster",
      "type": "string"
    },
    "within_hours": {
      "minimum": 1,
      "title": "Within Hours",
      "type": "integer"
    },
    "top_k": {
      "minimum": 1,
      "title": "Top K",
      "type": "integer"
    },
    "candidates": {
      "description": "Top-k submit windows ranked ascending by predicted_wait_sec. Empty when the diurnal predictor is cold across every queried hour.",
      "items": {
        "$ref": "#/$defs/_SubmitWindowCandidate"
      },
      "title": "Candidates",
      "type": "array"
    }
  },
  "$defs": {
    "_SubmitWindowCandidate": {
      "additionalProperties": false,
      "properties": {
        "submit_iso": {
          "description": "UTC, second-resolution.",
          "title": "Submit Iso",
          "type": "string"
        },
        "predicted_wait_sec": {
          "minimum": 0,
          "title": "Predicted Wait Sec",
          "type": "integer"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low",
            "cold"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "method": {
          "title": "Method",
          "type": "string"
        },
        "n_bucket_samples": {
          "minimum": 0,
          "title": "N Bucket Samples",
          "type": "integer"
        }
      },
      "required": [
        "submit_iso",
        "predicted_wait_sec",
        "confidence",
        "method",
        "n_bucket_samples"
      ],
      "title": "_SubmitWindowCandidate",
      "type": "object"
    }
  }
}
