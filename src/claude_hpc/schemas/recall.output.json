{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/recall.output.json",
  "title": "recall output envelope",
  "description": "Envelope returned by ``hpc-agent recall``.\n\nEach campaign summary projects the prior-decision fields the\nnext interviewer would compare against. The rollup block\npre-computes cross-campaign aggregations.",
  "type": "object",
  "required": [
    "ok",
    "data"
  ],
  "additionalProperties": false,
  "properties": {
    "ok": {
      "const": true,
      "title": "Ok",
      "type": "boolean"
    },
    "data": {
      "$ref": "#/$defs/_RecallData"
    }
  },
  "$defs": {
    "_CampaignSummary": {
      "additionalProperties": false,
      "properties": {
        "campaign_dir": {
          "title": "Campaign Dir",
          "type": "string"
        },
        "materialized_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "ISO-8601 timestamp from interview.json._materialized.at.",
          "title": "Materialized At"
        },
        "goal": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Goal"
        },
        "task_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Kind"
        },
        "task_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Count"
        },
        "operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator"
        },
        "produced_by_kind": {
          "anyOf": [
            {
              "enum": [
                "agent",
                "human"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Produced By Kind"
        },
        "cmd_sha": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{8,64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cmd Sha"
        },
        "budget": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget"
        },
        "abort_if": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Abort If"
        },
        "cluster_target": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cluster Target"
        },
        "task_generator": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Task Generator"
        }
      },
      "required": [
        "campaign_dir",
        "materialized_at"
      ],
      "title": "_CampaignSummary",
      "type": "object"
    },
    "_GeneratorByKindEntry": {
      "additionalProperties": true,
      "properties": {
        "count": {
          "minimum": 1,
          "title": "Count",
          "type": "integer"
        },
        "param_envelopes": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Param Envelopes"
        },
        "axis_value_unions": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Axis Value Unions"
        }
      },
      "required": [
        "count"
      ],
      "title": "_GeneratorByKindEntry",
      "type": "object"
    },
    "_GeneratorRollup": {
      "additionalProperties": false,
      "properties": {
        "by_kind": {
          "additionalProperties": {
            "$ref": "#/$defs/_GeneratorByKindEntry"
          },
          "title": "By Kind",
          "type": "object"
        }
      },
      "required": [
        "by_kind"
      ],
      "title": "_GeneratorRollup",
      "type": "object"
    },
    "_MaterializedAtStats": {
      "additionalProperties": false,
      "properties": {
        "earliest": {
          "title": "Earliest",
          "type": "string"
        },
        "latest": {
          "title": "Latest",
          "type": "string"
        }
      },
      "required": [
        "earliest",
        "latest"
      ],
      "title": "_MaterializedAtStats",
      "type": "object"
    },
    "_RecallData": {
      "additionalProperties": false,
      "properties": {
        "campaigns": {
          "items": {
            "$ref": "#/$defs/_CampaignSummary"
          },
          "title": "Campaigns",
          "type": "array"
        },
        "total_matching": {
          "minimum": 0,
          "title": "Total Matching",
          "type": "integer"
        },
        "showing": {
          "minimum": 0,
          "title": "Showing",
          "type": "integer"
        },
        "rollup": {
          "$ref": "#/$defs/_RecallRollup"
        }
      },
      "required": [
        "campaigns",
        "total_matching",
        "showing",
        "rollup"
      ],
      "title": "_RecallData",
      "type": "object"
    },
    "_RecallRollup": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "task_kind_distribution": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Task Kind Distribution",
          "type": "object"
        },
        "operators": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Operators",
          "type": "object"
        },
        "produced_by_kinds": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Produced By Kinds",
          "type": "object"
        },
        "task_generator_kinds": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Task Generator Kinds",
          "type": "object"
        },
        "clusters": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Clusters",
          "type": "object"
        },
        "task_count": {
          "anyOf": [
            {
              "$ref": "#/$defs/_TaskCountStats"
            },
            {
              "type": "null"
            }
          ]
        },
        "materialized_at": {
          "anyOf": [
            {
              "$ref": "#/$defs/_MaterializedAtStats"
            },
            {
              "type": "null"
            }
          ]
        },
        "runtime_rollup": {
          "anyOf": [
            {
              "$ref": "#/$defs/_RuntimeRollup"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "generator_rollup": {
          "anyOf": [
            {
              "$ref": "#/$defs/_GeneratorRollup"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "count",
        "task_kind_distribution",
        "operators",
        "produced_by_kinds",
        "task_generator_kinds",
        "clusters",
        "task_count",
        "materialized_at"
      ],
      "title": "_RecallRollup",
      "type": "object"
    },
    "_RuntimeRollup": {
      "additionalProperties": false,
      "properties": {
        "walltime_per_task_sec": {
          "anyOf": [
            {
              "$ref": "#/$defs/_WalltimeStats"
            },
            {
              "type": "null"
            }
          ]
        },
        "failure_rate": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure Rate"
        },
        "total_task_samples": {
          "minimum": 0,
          "title": "Total Task Samples",
          "type": "integer"
        },
        "campaigns_with_no_runtime": {
          "minimum": 0,
          "title": "Campaigns With No Runtime",
          "type": "integer"
        }
      },
      "required": [
        "walltime_per_task_sec",
        "total_task_samples",
        "campaigns_with_no_runtime"
      ],
      "title": "_RuntimeRollup",
      "type": "object"
    },
    "_TaskCountStats": {
      "additionalProperties": false,
      "properties": {
        "p50": {
          "title": "P50",
          "type": "number"
        },
        "p95": {
          "title": "P95",
          "type": "number"
        },
        "min": {
          "minimum": 0,
          "title": "Min",
          "type": "integer"
        },
        "max": {
          "minimum": 0,
          "title": "Max",
          "type": "integer"
        }
      },
      "required": [
        "p50",
        "p95",
        "min",
        "max"
      ],
      "title": "_TaskCountStats",
      "type": "object"
    },
    "_WalltimeStats": {
      "additionalProperties": false,
      "properties": {
        "p50": {
          "title": "P50",
          "type": "number"
        },
        "p95": {
          "title": "P95",
          "type": "number"
        },
        "min": {
          "title": "Min",
          "type": "integer"
        },
        "max": {
          "title": "Max",
          "type": "integer"
        },
        "n_samples": {
          "minimum": 0,
          "title": "N Samples",
          "type": "integer"
        }
      },
      "required": [
        "p50",
        "p95",
        "min",
        "max",
        "n_samples"
      ],
      "title": "_WalltimeStats",
      "type": "object"
    }
  }
}
