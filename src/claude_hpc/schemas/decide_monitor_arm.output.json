{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/decide_monitor_arm.output.json",
  "title": "decide-monitor-arm output",
  "description": "Decision record from decide-monitor-arm.\n\nThe slash-command epilogue copies armed_line verbatim and (when\narm == 'cron') passes cron_create_args to CronCreate.",
  "type": "object",
  "required": [
    "arm",
    "cadence_sec",
    "reason",
    "schedule",
    "armed_line",
    "cron_create_args"
  ],
  "additionalProperties": false,
  "properties": {
    "arm": {
      "enum": [
        "cron",
        "loop",
        "none"
      ],
      "title": "Arm",
      "type": "string"
    },
    "cadence_sec": {
      "minimum": 0,
      "title": "Cadence Sec",
      "type": "integer"
    },
    "reason": {
      "title": "Reason",
      "type": "string"
    },
    "schedule": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "Cron expression (e.g. '*/5 * * * *') when arm=='cron'; null otherwise.",
      "title": "Schedule"
    },
    "armed_line": {
      "description": "Literal final-line-of-stdout the slash command must emit; matches the Stop hook's regex by construction.",
      "title": "Armed Line",
      "type": "string"
    },
    "cron_create_args": {
      "anyOf": [
        {
          "$ref": "#/$defs/_CronCreateArgs"
        },
        {
          "type": "null"
        }
      ],
      "description": "Ready-to-pass keyword args for the CronCreate Claude Code tool when arm=='cron'; null otherwise."
    }
  },
  "$defs": {
    "_CronCreateArgs": {
      "additionalProperties": false,
      "properties": {
        "schedule": {
          "title": "Schedule",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "schedule",
        "prompt",
        "reason"
      ],
      "title": "_CronCreateArgs",
      "type": "object"
    }
  }
}
