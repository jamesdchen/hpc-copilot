{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/build_tasks_py.input.json",
  "title": "build-tasks-py input",
  "description": "Cartesian-product axes spec + per-executor flag declarations.\n\nDrives ``claude_hpc.atoms.build_tasks_py`` to scaffold\n``<experiment>/.hpc/tasks.py``.",
  "type": "object",
  "required": [
    "axes",
    "flags_by_executor"
  ],
  "additionalProperties": false,
  "properties": {
    "axes": {
      "items": {
        "$ref": "#/$defs/_AxisSpec"
      },
      "minItems": 1,
      "title": "Axes",
      "type": "array"
    },
    "flags_by_executor": {
      "additionalProperties": {
        "items": {
          "$ref": "#/$defs/_FlagSpec"
        },
        "type": "array"
      },
      "minProperties": 1,
      "title": "Flags By Executor",
      "type": "object"
    },
    "force": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Force"
    }
  },
  "$defs": {
    "_AxisSpec": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "values": {
          "items": {},
          "minItems": 1,
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "name",
        "values"
      ],
      "title": "_AxisSpec",
      "type": "object"
    },
    "_FlagSpec": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "type": {
          "description": "One of int|float|str|bool — the four ctors the scaffold knows how to emit.",
          "enum": [
            "int",
            "float",
            "str",
            "bool"
          ],
          "title": "Type",
          "type": "string"
        },
        "default": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "_FlagSpec",
      "type": "object"
    }
  }
}
