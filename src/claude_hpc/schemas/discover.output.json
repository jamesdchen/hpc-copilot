{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/discover.output.json",
  "title": "discover output data",
  "type": "object",
  "required": [
    "executors"
  ],
  "additionalProperties": false,
  "properties": {
    "executors": {
      "items": {
        "$ref": "#/$defs/_ExecutorEntry"
      },
      "title": "Executors",
      "type": "array"
    },
    "meta": {
      "anyOf": [
        {
          "$ref": "#/$defs/_DiscoverMeta"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Integrator-supplied experiment context, extracted from meta.json. Present only when meta.json exists at the experiment-dir root."
    }
  },
  "$defs": {
    "_DiscoverMeta": {
      "additionalProperties": true,
      "description": "Integrator-supplied experiment context, extracted from meta.json.",
      "properties": {
        "experiment_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Experiment Id"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "purpose": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Purpose"
        },
        "tier": {
          "anyOf": [
            {
              "enum": [
                1,
                2
              ],
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tier"
        }
      },
      "title": "_DiscoverMeta",
      "type": "object"
    },
    "_ExecutorEntry": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "cli_framework": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cli Framework"
        },
        "has_main_guard": {
          "title": "Has Main Guard",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "path",
        "has_main_guard"
      ],
      "title": "_ExecutorEntry",
      "type": "object"
    }
  }
}
