{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/find_prior_run.output.json",
  "title": "find-prior-run output",
  "description": "Resume-detection lookup result.\n\nfound=False distinguishes 'no prior run' from 'prior run is\norphan' (is_orphan=True signals a half-baked sidecar). The\nprior_run_id field is named with a 'prior_' prefix so the\nschema-defs consistency check (which forbids nullable run_id)\ndoesn't trip.",
  "type": "object",
  "required": [
    "found",
    "prior_run_id",
    "is_orphan",
    "status",
    "age_sec",
    "profile",
    "cluster",
    "job_ids",
    "campaign_id",
    "submitted_at"
  ],
  "properties": {
    "found": {
      "title": "Found",
      "type": "boolean"
    },
    "prior_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "The matching prior run's run_id, or null when found=False.",
      "title": "Prior Run Id"
    },
    "is_orphan": {
      "title": "Is Orphan",
      "type": "boolean"
    },
    "status": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Status"
    },
    "age_sec": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "title": "Age Sec"
    },
    "profile": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Profile"
    },
    "cluster": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Cluster"
    },
    "job_ids": {
      "items": {
        "type": "string"
      },
      "title": "Job Ids",
      "type": "array"
    },
    "campaign_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Campaign Id"
    },
    "submitted_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Submitted At"
    }
  }
}
