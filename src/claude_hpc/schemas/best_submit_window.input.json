{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/best_submit_window.input.json",
  "title": "best-submit-window input",
  "description": "Inputs for the ``best-submit-window`` primitive.",
  "type": "object",
  "required": [
    "profile",
    "cluster"
  ],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "title": "Profile",
      "type": "string"
    },
    "cluster": {
      "title": "Cluster",
      "type": "string"
    },
    "within_hours": {
      "default": 24,
      "minimum": 1,
      "title": "Within Hours",
      "type": "integer"
    },
    "top_k": {
      "default": 5,
      "minimum": 1,
      "title": "Top K",
      "type": "integer"
    }
  }
}
