{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/verify_aggregation_complete.output.json",
  "title": "verify-aggregation-complete output",
  "description": "Post-aggregate invariant report.\n\nAgent reads ``ok`` and surfaces violations\n(missing_waves / missing_tasks / unexpected_tasks /\nprovenance_present) to the user.",
  "type": "object",
  "required": [
    "ok",
    "run_id",
    "all_waves_combined",
    "missing_waves",
    "all_tasks_present",
    "missing_tasks",
    "unexpected_tasks",
    "provenance_present",
    "expected_wave_count",
    "pulled_wave_count",
    "expected_task_count",
    "pulled_task_count"
  ],
  "properties": {
    "ok": {
      "title": "Ok",
      "type": "boolean"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "all_waves_combined": {
      "title": "All Waves Combined",
      "type": "boolean"
    },
    "missing_waves": {
      "items": {
        "type": "integer"
      },
      "title": "Missing Waves",
      "type": "array"
    },
    "all_tasks_present": {
      "title": "All Tasks Present",
      "type": "boolean"
    },
    "missing_tasks": {
      "items": {
        "type": "integer"
      },
      "title": "Missing Tasks",
      "type": "array"
    },
    "unexpected_tasks": {
      "description": "Cross-run contamination: task_ids in pulled partials but not in this run's wave_map.",
      "items": {
        "type": "integer"
      },
      "title": "Unexpected Tasks",
      "type": "array"
    },
    "unexpected_aggregated_keys": {
      "description": "Post-reduce contamination: keys in the supplied ``aggregated_metrics`` dict that don't match any grid-point produced by ``tasks.resolve(i)`` for i in [0, total_tasks). Only populated when the caller supplied ``aggregated_metrics`` + ``aggregated_keying='grid_point'``; empty list otherwise.",
      "items": {
        "type": "string"
      },
      "title": "Unexpected Aggregated Keys",
      "type": "array"
    },
    "provenance_present": {
      "title": "Provenance Present",
      "type": "boolean"
    },
    "expected_wave_count": {
      "minimum": 0,
      "title": "Expected Wave Count",
      "type": "integer"
    },
    "pulled_wave_count": {
      "minimum": 0,
      "title": "Pulled Wave Count",
      "type": "integer"
    },
    "expected_task_count": {
      "minimum": 0,
      "title": "Expected Task Count",
      "type": "integer"
    },
    "pulled_task_count": {
      "minimum": 0,
      "title": "Pulled Task Count",
      "type": "integer"
    }
  }
}
