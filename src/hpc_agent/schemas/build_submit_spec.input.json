{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/build_submit_spec.input.json",
  "title": "build-submit-spec input",
  "description": "Resolved interview values fed to ``hpc_agent.incorporation.build.submit_spec``.\n\nThe primitive synthesizes the framework-required job_env keys\nand emits a validated submit_flow.input.json spec ready for\nsubmit-flow.",
  "type": "object",
  "required": [
    "profile",
    "cluster",
    "ssh_target",
    "remote_path",
    "run_id",
    "cmd_sha",
    "total_tasks",
    "backend"
  ],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "minLength": 1,
      "title": "Profile",
      "type": "string"
    },
    "cluster": {
      "minLength": 1,
      "title": "Cluster",
      "type": "string"
    },
    "ssh_target": {
      "pattern": "^[^@]+@[^@]+$",
      "title": "Ssh Target",
      "type": "string"
    },
    "remote_path": {
      "minLength": 1,
      "title": "Remote Path",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[A-Za-z0-9._\\-]+$",
      "title": "Run Id",
      "type": "string"
    },
    "cmd_sha": {
      "pattern": "^[0-9a-f]{8,64}$",
      "title": "Cmd Sha",
      "type": "string"
    },
    "total_tasks": {
      "minimum": 1,
      "title": "Total Tasks",
      "type": "integer"
    },
    "backend": {
      "title": "Backend",
      "type": "string"
    },
    "is_gpu": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Is Gpu"
    },
    "job_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Job Name"
    },
    "script": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Script"
    },
    "modules": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Modules"
    },
    "conda_source": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Conda Source"
    },
    "conda_env": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Conda Env"
    },
    "runtime": {
      "anyOf": [
        {
          "const": "uv",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Runtime"
    },
    "campaign_id": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z0-9._\\-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Campaign Id"
    },
    "result_dir_template": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Result Dir Template"
    },
    "walltime_sec": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Walltime Sec"
    },
    "mem_mb": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mem Mb"
    },
    "cpus": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cpus"
    },
    "mpi": {
      "anyOf": [
        {
          "$ref": "#/$defs/MpiSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "canary": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Canary"
    },
    "partial_ok": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Partial Ok"
    },
    "invalidate_on_code_change": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Invalidate On Code Change"
    },
    "pass_env_keys": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pass Env Keys"
    },
    "rsync_excludes": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rsync Excludes"
    },
    "slurm_account": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Slurm Account"
    },
    "slurm_cluster": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Slurm Cluster"
    },
    "extra_env": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extra Env"
    },
    "service_env": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Service Env"
    }
  },
  "$defs": {
    "MpiSpec": {
      "additionalProperties": false,
      "description": "Multi-rank job shape: N ranks across M nodes as ONE unit of work (#293).\n\nhpc-agent's default axis is independent-task fan-out (one task = one\nprocess). An MPI solve breaks that shape — a single computation spans\n``ranks`` processes that coordinate via the MPI library, and the whole\nmulti-rank job is one unit of work. This block, hung on\n:class:`SubmitResources`, carries the rank/topology controls; the\nbackend's ``resource_flags`` translates them into scheduler directives\n(``--ntasks`` / ``-pe`` / ``select=``) and the ``mpi`` job template wraps\nthe executor in the chosen ``launcher``.\n\nEvery field but ``ranks`` is optional. ``ranks_per_node`` left null lets\nthe scheduler pack ranks onto nodes; set it to pin the decomposition\n(then ``nodes = ranks / ranks_per_node`` and the divisibility guard\nbelow fires on an incoherent combo).",
      "properties": {
        "ranks": {
          "description": "Total MPI ranks (processes) for the job. SLURM --ntasks / SGE -pe <pe> N.",
          "minimum": 1,
          "title": "Ranks",
          "type": "integer"
        },
        "ranks_per_node": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Ranks packed onto each node. Null lets the scheduler decide. When set, must divide ``ranks`` evenly so node count is integral.",
          "title": "Ranks Per Node"
        },
        "threads_per_rank": {
          "default": 1,
          "description": "OpenMP threads per rank (hybrid MPI+OpenMP). SLURM --cpus-per-task.",
          "minimum": 1,
          "title": "Threads Per Rank",
          "type": "integer"
        },
        "launcher": {
          "description": "How the job template launches the ranks: srun / mpirun / aprun.",
          "enum": [
            "srun",
            "mpirun",
            "aprun"
          ],
          "title": "Launcher",
          "type": "string"
        },
        "pe_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "SGE parallel environment to request (``-pe <pe_name> <ranks>``). Resolved from inspect-cluster's parallel_environments (kind=mpi). Required for SGE; ignored by SLURM/PBS.",
          "title": "Pe Name"
        }
      },
      "required": [
        "ranks",
        "launcher"
      ],
      "title": "mpi spec",
      "type": "object"
    }
  }
}
