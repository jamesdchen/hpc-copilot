{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/envelope.json",
  "$defs": {
    "ErrorEnvelope": {
      "additionalProperties": false,
      "description": "The ``ok=false`` shape of every hpc-agent stdout response.",
      "properties": {
        "ok": {
          "const": false,
          "title": "Ok",
          "type": "boolean"
        },
        "error_code": {
          "enum": [
            "ssh_unreachable",
            "scheduler_throttled",
            "spec_invalid",
            "executor_not_found",
            "cluster_unknown",
            "journal_corrupt",
            "remote_command_failed",
            "config_invalid",
            "combiner_failed",
            "cluster_timeout",
            "cluster_partially_degraded",
            "outputs_missing",
            "schema_incompat",
            "preempted",
            "internal"
          ],
          "title": "Error Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "category": {
          "enum": [
            "user",
            "cluster",
            "network",
            "internal"
          ],
          "title": "Category",
          "type": "string"
        },
        "retry_safe": {
          "title": "Retry Safe",
          "type": "boolean"
        },
        "remediation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remediation"
        }
      },
      "required": [
        "ok",
        "error_code",
        "message",
        "category",
        "retry_safe"
      ],
      "title": "ErrorEnvelope",
      "type": "object"
    },
    "SuccessEnvelope": {
      "additionalProperties": false,
      "description": "The ``ok=true`` shape of every hpc-agent stdout response.",
      "properties": {
        "ok": {
          "const": true,
          "title": "Ok",
          "type": "boolean"
        },
        "idempotent": {
          "title": "Idempotent",
          "type": "boolean"
        },
        "data": {
          "additionalProperties": true,
          "title": "Data",
          "type": "object"
        },
        "partial_errors": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/_PartialError"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional top-level array surfacing soft per-source failures while the operation as a whole succeeded.",
          "title": "Partial Errors"
        }
      },
      "required": [
        "ok",
        "idempotent",
        "data"
      ],
      "title": "SuccessEnvelope",
      "type": "object"
    },
    "_PartialError": {
      "additionalProperties": false,
      "description": "One soft per-source failure surfaced on a successful envelope.\n\nDistinct from ``data.errors``: this key documents *cluster-side*\ndegradations (qhost timed out, one of N nodes unreachable, sacct\nunavailable) that the planner considered and chose to tolerate.\nOperations that genuinely failed should set ``ok: false`` instead.",
      "properties": {
        "code": {
          "description": "Machine-readable category, e.g. 'qhost_failed', 'scontrol_failed', 'qstat_unavailable', 'qacct_unavailable', 'malformed_row'.",
          "title": "Code",
          "type": "string"
        },
        "detail": {
          "title": "Detail",
          "type": "string"
        }
      },
      "required": [
        "code",
        "detail"
      ],
      "title": "_PartialError",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "False": "#/$defs/ErrorEnvelope",
      "True": "#/$defs/SuccessEnvelope"
    },
    "propertyName": "ok"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/SuccessEnvelope"
    },
    {
      "$ref": "#/$defs/ErrorEnvelope"
    }
  ]
}
