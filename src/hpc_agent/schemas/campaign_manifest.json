{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/campaign_manifest.json",
  "title": "campaign manifest",
  "description": "Schema for ``<campaign_dir>/manifest.json``.",
  "type": "object",
  "required": [
    "manifest_schema_version",
    "campaign_id"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_schema_version": {
      "const": 1,
      "title": "Manifest Schema Version",
      "type": "integer"
    },
    "campaign_id": {
      "minLength": 1,
      "title": "Campaign Id",
      "type": "string"
    },
    "created_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ISO-8601 timestamp.",
      "title": "Created At"
    },
    "goal": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Free-form prose; framework treats as opaque text (not parsed).",
      "title": "Goal"
    },
    "budget": {
      "anyOf": [
        {
          "$ref": "#/$defs/_CampaignBudget"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "stop_criteria": {
      "anyOf": [
        {
          "$ref": "#/$defs/_StopCriteria"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "strategy": {
      "anyOf": [
        {
          "$ref": "#/$defs/_Strategy"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "$defs": {
    "_CampaignBudget": {
      "additionalProperties": false,
      "properties": {
        "max_jobs": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Jobs"
        },
        "max_tasks": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tasks"
        },
        "max_walltime_sec": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Walltime Sec"
        }
      },
      "title": "_CampaignBudget",
      "type": "object"
    },
    "_StopCriteria": {
      "additionalProperties": false,
      "properties": {
        "max_iters": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Iters"
        },
        "metric": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric"
        },
        "target": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target"
        },
        "direction": {
          "anyOf": [
            {
              "enum": [
                "minimize",
                "maximize"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Direction"
        },
        "plateau_window": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Plateau Window"
        },
        "plateau_tolerance": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Plateau Tolerance"
        }
      },
      "title": "_StopCriteria",
      "type": "object"
    },
    "_Strategy": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "Free string for human/agent display only; framework never dispatches on this.",
          "title": "Name",
          "type": "string"
        },
        "params": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Opaque to the framework. Round-tripped untouched.",
          "title": "Params"
        }
      },
      "required": [
        "name"
      ],
      "title": "_Strategy",
      "type": "object"
    }
  }
}
