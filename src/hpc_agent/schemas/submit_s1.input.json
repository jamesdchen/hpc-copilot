{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/submit_s1.input.json",
  "title": "submit-s1 input spec",
  "description": "Inputs to ``submit-s1`` (resolve).\n\n``walk`` drives the deterministic ambiguity walk (the envelope machinery,\nunchanged). ``resolve`` is the OPTIONAL post-resolution input-resolution\nchain — supplied on a re-invocation after the human resolved the S1\nambiguities, so the block can reach a clean ``resolved`` (submit-flow spec\nbuilt) or a ``prior_run_found`` terminator in one pass.",
  "type": "object",
  "required": [
    "walk"
  ],
  "additionalProperties": false,
  "properties": {
    "walk": {
      "$ref": "#/$defs/WalkSubmitAmbiguitiesInput",
      "description": "The walk-submit-ambiguities inputs. Each unresolved AUTO_RESOLVABLE field's safe_default is surfaced in the brief as a RECOMMENDATION, never auto-applied into resolved."
    },
    "run_preflight": {
      "default": true,
      "description": "Run submit-preflight (install-commands → load-context → check-preflight ∥ resolve-resources) before the walk and fold its overall pass/fail into the brief. Disable for a pure local resolve.",
      "title": "Run Preflight",
      "type": "boolean"
    },
    "resolve": {
      "anyOf": [
        {
          "$ref": "#/$defs/ResolveSubmitInputsSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional resolve-submit-inputs spec. Run ONLY when the walk found no ambiguities (all fields caller-supplied or auto-resolved), to reach the clean resolved / prior_run_found / needs_scaffold_interview terminator. Null stops S1 at the ambiguity brief."
    }
  },
  "$defs": {
    "BuildSubmitSpecInput": {
      "additionalProperties": false,
      "description": "Resolved interview values fed to ``hpc_agent.incorporation.build.submit_spec``.\n\nThe primitive synthesizes the framework-required job_env keys\nand emits a validated submit_flow.input.json spec ready for\nsubmit-flow.",
      "properties": {
        "profile": {
          "minLength": 1,
          "title": "Profile",
          "type": "string"
        },
        "cluster": {
          "minLength": 1,
          "title": "Cluster",
          "type": "string"
        },
        "ssh_target": {
          "pattern": "^[^@]+@[^@]+$",
          "title": "Ssh Target",
          "type": "string"
        },
        "remote_path": {
          "minLength": 1,
          "title": "Remote Path",
          "type": "string"
        },
        "run_id": {
          "pattern": "^[A-Za-z0-9._\\-]+$",
          "title": "Run Id",
          "type": "string"
        },
        "cmd_sha": {
          "pattern": "^[0-9a-f]{8,64}$",
          "title": "Cmd Sha",
          "type": "string"
        },
        "total_tasks": {
          "minimum": 1,
          "title": "Total Tasks",
          "type": "integer"
        },
        "backend": {
          "title": "Backend",
          "type": "string"
        },
        "is_gpu": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Is Gpu"
        },
        "job_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Job Name"
        },
        "script": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Script"
        },
        "modules": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modules"
        },
        "conda_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conda Source"
        },
        "conda_env": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conda Env"
        },
        "runtime": {
          "anyOf": [
            {
              "const": "uv",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runtime"
        },
        "campaign_id": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z0-9._\\-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Campaign Id"
        },
        "result_dir_template": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Dir Template"
        },
        "walltime_sec": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Walltime Sec"
        },
        "mem_mb": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mem Mb"
        },
        "cpus": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cpus"
        },
        "mpi": {
          "anyOf": [
            {
              "$ref": "#/$defs/MpiSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "canary": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Canary"
        },
        "partial_ok": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Partial Ok"
        },
        "invalidate_on_code_change": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invalidate On Code Change"
        },
        "pass_env_keys": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pass Env Keys"
        },
        "rsync_excludes": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rsync Excludes"
        },
        "slurm_account": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slurm Account"
        },
        "slurm_cluster": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slurm Cluster"
        },
        "extra_env": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extra Env"
        },
        "service_env": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service Env"
        }
      },
      "required": [
        "profile",
        "cluster",
        "ssh_target",
        "remote_path",
        "run_id",
        "cmd_sha",
        "total_tasks",
        "backend"
      ],
      "title": "build-submit-spec input",
      "type": "object"
    },
    "BuildTasksPyInput": {
      "additionalProperties": false,
      "description": "Axes spec + per-executor flag declarations for the ``tasks.py`` scaffold.\n\nDrives ``hpc_agent.incorporation.build.tasks_py`` to scaffold\n``<experiment>/.hpc/tasks.py``. Two modes:\n\n* **cartesian** (``data_axis`` omitted) — ``axes`` is a cartesian\n  product, one independent task per cell.\n* **planner** (``data_axis`` present) — ``axes`` is the *sweep* and\n  the series axis is partitioned by ``hpc_agent.experiment_kit.plan_tasks``\n  per the classified ``DataAxis``.",
      "properties": {
        "axes": {
          "items": {
            "$ref": "#/$defs/_AxisSpec"
          },
          "minItems": 1,
          "title": "Axes",
          "type": "array"
        },
        "flags_by_executor": {
          "additionalProperties": {
            "items": {
              "$ref": "#/$defs/_FlagSpec"
            },
            "type": "array"
          },
          "minProperties": 1,
          "title": "Flags By Executor",
          "type": "object"
        },
        "force": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Force"
        },
        "data_axis": {
          "anyOf": [
            {
              "$ref": "#/$defs/_DataAxisSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "When set, emit a planner-driven tasks.py instead of a cartesian one."
        }
      },
      "required": [
        "axes",
        "flags_by_executor"
      ],
      "title": "build-tasks-py input",
      "type": "object"
    },
    "MpiSpec": {
      "additionalProperties": false,
      "description": "Multi-rank job shape: N ranks across M nodes as ONE unit of work (#293).\n\nhpc-agent's default axis is independent-task fan-out (one task = one\nprocess). An MPI solve breaks that shape — a single computation spans\n``ranks`` processes that coordinate via the MPI library, and the whole\nmulti-rank job is one unit of work. This block, hung on\n:class:`SubmitResources`, carries the rank/topology controls; the\nbackend's ``resource_flags`` translates them into scheduler directives\n(``--ntasks`` / ``-pe`` / ``select=``) and the ``mpi`` job template wraps\nthe executor in the chosen ``launcher``.\n\nEvery field but ``ranks`` is optional. ``ranks_per_node`` left null lets\nthe scheduler pack ranks onto nodes; set it to pin the decomposition\n(then ``nodes = ranks / ranks_per_node`` and the divisibility guard\nbelow fires on an incoherent combo).",
      "properties": {
        "ranks": {
          "description": "Total MPI ranks (processes) for the job. SLURM --ntasks / SGE -pe <pe> N.",
          "minimum": 1,
          "title": "Ranks",
          "type": "integer"
        },
        "ranks_per_node": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Ranks packed onto each node. Null lets the scheduler decide. When set, must divide ``ranks`` evenly so node count is integral.",
          "title": "Ranks Per Node"
        },
        "threads_per_rank": {
          "default": 1,
          "description": "OpenMP threads per rank (hybrid MPI+OpenMP). SLURM --cpus-per-task.",
          "minimum": 1,
          "title": "Threads Per Rank",
          "type": "integer"
        },
        "launcher": {
          "description": "How the job template launches the ranks: srun / mpirun / aprun.",
          "enum": [
            "srun",
            "mpirun",
            "aprun"
          ],
          "title": "Launcher",
          "type": "string"
        },
        "pe_name": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "SGE parallel environment to request (``-pe <pe_name> <ranks>``). Resolved from inspect-cluster's parallel_environments (kind=mpi). Required for SGE; ignored by SLURM/PBS.",
          "title": "Pe Name"
        }
      },
      "required": [
        "ranks",
        "launcher"
      ],
      "title": "mpi spec",
      "type": "object"
    },
    "PartitionInfo": {
      "additionalProperties": false,
      "description": "One partition the cluster exposes, with its scheduling shape.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "priority_tier": {
          "default": 1,
          "minimum": 1,
          "title": "Priority Tier",
          "type": "integer"
        },
        "walltime_cap_sec": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Walltime Cap Sec"
        },
        "is_debug": {
          "default": false,
          "title": "Is Debug",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "PartitionInfo",
      "type": "object"
    },
    "ResolveSubmitInputsSpec": {
      "additionalProperties": false,
      "description": "Spec passed to ``hpc-agent resolve-submit-inputs --spec <file>``.\n\nCarries exactly the values the deterministic chain needs that the\ncaller has already resolved upstream: the human-chosen ``run_name``\n(drives ``compute-run-id``), the full ``build-submit-spec`` input\n(re-used verbatim so cluster / profile / backend / job_env / etc. are\nnot re-enumerated here), and an optional ``build_tasks`` scaffold spec\nused only when ``.hpc/tasks.py`` is absent. ``experiment_dir`` is the\nframework-context positional arg, intentionally NOT a spec field.",
      "properties": {
        "run_name": {
          "description": "Human-chosen run name fed to compute-run-id; combined with the cmd_sha prefix to form run_id (<run_name>-<sha[:8]>).",
          "minLength": 1,
          "title": "Run Name",
          "type": "string"
        },
        "submit": {
          "$ref": "#/$defs/BuildSubmitSpecInput",
          "description": "The resolved build-submit-spec input (profile / cluster / ssh_target / remote_path / total_tasks / backend / job_env knobs). resolve-submit-inputs feeds this to build-submit-spec to assemble the validated submit-flow spec after the run_id / prior-run / tasks.py branches clear. Its ``run_id`` / ``cmd_sha`` are PLACEHOLDERS — the composite overrides them with the values compute-run-id derives, so the built spec always matches the reported run_id."
        },
        "sidecar": {
          "$ref": "#/$defs/WriteRunSidecarInput",
          "description": "The resolved write-run-sidecar input (the v2 config snapshot: the REAL per-task ``executor``, result_dir_template, task_count, resources, env, constraints, runtime). resolve-submit-inputs writes the per-run sidecar from this on the ``resolved`` path, so the output is fully submit-ready (the #171 write-first precondition is already satisfied before submit-pipeline runs). Its ``run_id`` / ``cmd_sha`` are PLACEHOLDERS overridden with compute-run-id's values."
        },
        "build_tasks": {
          "anyOf": [
            {
              "$ref": "#/$defs/BuildTasksPyInput"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional pre-classified build-tasks-py spec (axes + flags_by_executor + optional data_axis). Used ONLY when <experiment_dir>/.hpc/tasks.py is absent and can be scaffolded deterministically. When tasks.py is absent and this is null, the composite escalates needs_scaffold_interview rather than guessing."
        },
        "reproduction_of": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Reproduction-receipt lever: the run_id of an ORIGINAL run this resolution deliberately REPRODUCES with identical params. cmd_sha is parameter identity, so a re-run of the same params otherwise stops at prior_run_found against the (even complete) original. Naming it here makes find-prior-run skip the original (and any prior reproduction of it) — so a `complete` original no longer terminates resolve, while ANY OTHER live prior still does — and stamps ``reproduces`` onto the derived run's sidecar so a later reproduction of the same original skips this one too. It is also threaded onto the built submit-flow spec so the submit-time layer-2 dedup pierces the same original. Null = ordinary submit.",
          "title": "Reproduction Of"
        }
      },
      "required": [
        "run_name",
        "submit",
        "sidecar"
      ],
      "title": "resolve-submit-inputs input spec",
      "type": "object"
    },
    "WalkSubmitAmbiguitiesInput": {
      "additionalProperties": false,
      "description": "Inputs to the deterministic submit-input walk (SKILL Steps 2-6).\n\nEach caller-supplied field short-circuits its resolution step (the\n\"caller-supplied is authoritative\" contract). Absent fields are\nresolved by a deterministic rule where one exists, or accumulated as\nan :class:`~hpc_agent.ops.submit.field_partition.Ambiguity`.",
      "properties": {
        "cluster": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Caller-resolved cluster; else auto-resolved from configured_clusters.",
          "title": "Cluster"
        },
        "configured_clusters": {
          "description": "Clusters configured in clusters.yaml. One → auto-use; multiple → ambiguity with safe_default = first lexicographically.",
          "items": {
            "type": "string"
          },
          "title": "Configured Clusters",
          "type": "array"
        },
        "goal": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Free-text campaign goal. REQUIRED_CALLER_FIELDS — when absent it is surfaced WITHOUT a safe_default (the guard forbids one).",
          "title": "Goal"
        },
        "task_generator": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "cartesian_product": "#/$defs/_CartesianProduct",
                  "enumerated": "#/$defs/_Enumerated",
                  "items_x_seeds": "#/$defs/_ItemsXSeeds",
                  "numeric_linspace": "#/$defs/_NumericLinspace",
                  "numeric_logspace": "#/$defs/_NumericLogspace"
                },
                "propertyName": "kind"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/_Enumerated"
                },
                {
                  "$ref": "#/$defs/_CartesianProduct"
                },
                {
                  "$ref": "#/$defs/_ItemsXSeeds"
                },
                {
                  "$ref": "#/$defs/_NumericLogspace"
                },
                {
                  "$ref": "#/$defs/_NumericLinspace"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The sweep recipe. REQUIRED_CALLER_FIELDS — the framework cannot invent it. Absent (and no tasks.py) → surfaced WITHOUT a safe_default.",
          "title": "Task Generator"
        },
        "tasks_py_present": {
          "default": false,
          "description": "Whether .hpc/tasks.py already exists. When true, an absent task_generator is NOT an ambiguity (the hand-written tasks.py path).",
          "title": "Tasks Py Present",
          "type": "boolean"
        },
        "entry_point_resolved": {
          "default": false,
          "description": "Whether the entry point is resolved (a @register_run / interview.json on disk).",
          "title": "Entry Point Resolved",
          "type": "boolean"
        },
        "entry_point_candidates": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Candidate entry-point paths when unresolved (e.g. ['train.py', 'main.py']).",
          "title": "Entry Point Candidates"
        },
        "uncovered_required_params": {
          "description": "Required (no-default) executor params that are NOT swept axes and lack a fixed_params value. Each must be covered or every task crashes.",
          "items": {
            "type": "string"
          },
          "title": "Uncovered Required Params",
          "type": "array"
        },
        "uncovered_param_defaults": {
          "additionalProperties": true,
          "description": "Per-param argparse default where one exists (e.g. {'samples': 10000}). Feeds the uncovered_param safe_default's {param: <default-or-null>} map.",
          "title": "Uncovered Param Defaults",
          "type": "object"
        },
        "executor_run_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The executor's run_name; surfaced in the uncovered_param context block.",
          "title": "Executor Run Name"
        },
        "data_axis_resolved": {
          "default": false,
          "description": "Whether axes.yaml has an executors.<run_name> entry for the current sha.",
          "title": "Data Axis Resolved",
          "type": "boolean"
        },
        "homogeneous_axes_resolved": {
          "default": false,
          "description": "Whether axes.yaml carries homogeneous_axes.",
          "title": "Homogeneous Axes Resolved",
          "type": "boolean"
        },
        "experiment_dir": {
          "default": ".",
          "description": "Experiment directory; passed to resolve-resources.",
          "title": "Experiment Dir",
          "type": "string"
        },
        "profile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Run profile (run_name); resolve-resources prior key.",
          "title": "Profile"
        },
        "cmd_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional cmd_sha for the runtime prior.",
          "title": "Cmd Sha"
        },
        "walltime_sec": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Caller override for walltime_sec.",
          "title": "Walltime Sec"
        },
        "gpu_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Caller override for gpu_type.",
          "title": "Gpu Type"
        },
        "partition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Caller override for partition.",
          "title": "Partition"
        },
        "user_preferred_partition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Soft partition preference forwarded to recommend-partition.",
          "title": "User Preferred Partition"
        },
        "partitions": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/PartitionInfo"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The cluster's partition list (for recommend-partition).",
          "title": "Partitions"
        },
        "mpi_pe": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Caller override for the SGE parallel env.",
          "title": "Mpi Pe"
        },
        "mpi_ranks": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Total MPI ranks; when set, mpi_pe is auto-derived.",
