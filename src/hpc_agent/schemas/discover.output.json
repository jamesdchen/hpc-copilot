{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/discover.output.json",
  "title": "discover output data",
  "type": "object",
  "required": [
    "executors"
  ],
  "additionalProperties": false,
  "properties": {
    "executors": {
      "items": {
        "$ref": "#/$defs/_ExecutorEntry"
      },
      "title": "Executors",
      "type": "array"
    }
  },
  "$defs": {
    "_ExecutorEntry": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "cli_framework": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cli Framework"
        },
        "has_main_guard": {
          "title": "Has Main Guard",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "path",
        "has_main_guard"
      ],
      "title": "_ExecutorEntry",
      "type": "object"
    }
  }
}
