{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/recommend_partition.output.json",
  "title": "RecommendPartitionResult",
  "type": "object",
  "required": [
    "recommended_partition",
    "rationale",
    "message"
  ],
  "additionalProperties": false,
  "properties": {
    "recommended_partition": {
      "minLength": 1,
      "title": "Recommended Partition",
      "type": "string"
    },
    "rationale": {
      "enum": [
        "user_preference_honoured",
        "debug_short_walltime",
        "debug_overrun_refused",
        "default_long_walltime",
        "no_debug_partition_available",
        "no_partitions_declared",
        "only_debug_available_walltime_too_long"
      ],
      "title": "Rationale",
      "type": "string"
    },
    "message": {
      "title": "Message",
      "type": "string"
    },
    "leverage_estimate": {
      "default": 1.0,
      "description": "Multiplicative speedup the recommendation buys vs. the default partition (PriorityTier ratio). 10.0 means 10x backfill leverage.",
      "minimum": 0.0,
      "title": "Leverage Estimate",
      "type": "number"
    }
  }
}
