{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/clusters_list.output.json",
  "title": "clusters list output data",
  "description": "Shape of the ``data`` field on a successful ``clusters list`` envelope.",
  "type": "object",
  "required": [
    "clusters"
  ],
  "additionalProperties": false,
  "properties": {
    "clusters": {
      "items": {
        "$ref": "#/$defs/_ClusterListEntry"
      },
      "title": "Clusters",
      "type": "array"
    }
  },
  "$defs": {
    "_ClusterListEntry": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "host": {
          "title": "Host",
          "type": "string"
        },
        "scheduler": {
          "enum": [
            "sge",
            "slurm"
          ],
          "title": "Scheduler",
          "type": "string"
        }
      },
      "required": [
        "name",
        "host",
        "scheduler"
      ],
      "title": "_ClusterListEntry",
      "type": "object"
    }
  }
}
