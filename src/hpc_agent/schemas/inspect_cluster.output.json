{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/inspect_cluster.output.json",
  "title": "inspect-cluster output data",
  "type": "object",
  "required": [
    "cluster",
    "scheduler_kind",
    "now_iso",
    "nodes",
    "errors"
  ],
  "additionalProperties": false,
  "properties": {
    "cluster": {
      "title": "Cluster",
      "type": "string"
    },
    "scheduler_kind": {
      "enum": [
        "sge",
        "slurm",
        "pbspro",
        "torque"
      ],
      "title": "Scheduler Kind",
      "type": "string"
    },
    "now_iso": {
      "description": "UTC ISO-8601 timestamp of the snapshot.",
      "title": "Now Iso",
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/_NodeSnapshot"
      },
      "title": "Nodes",
      "type": "array"
    },
    "errors": {
      "description": "Non-fatal per-node errors (e.g. one node failed to report). Fatal cases raise ssh_unreachable instead.",
      "items": {
        "type": "string"
      },
      "title": "Errors",
      "type": "array"
    },
    "parallel_environments": {
      "description": "Scheduler 'parallel environments' — the named pools you target for (multi-rank) work — normalized across SGE PEs (qconf -spl/-sp), SLURM partitions (scontrol show partition), and PBS execution queues (qstat -Qf) onto one shape. Empty pre-#293 or when none are exposed.",
      "items": {
        "$ref": "#/$defs/_ParallelEnvironment"
      },
      "title": "Parallel Environments",
      "type": "array"
    }
  },
  "$defs": {
    "_NodeSnapshot": {
      "additionalProperties": true,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "alloc_mem_pct": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alloc Mem Pct"
        },
        "cpu_load_frac": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cpu Load Frac"
        },
        "gres": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gres"
        },
        "gres_used": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gres Used"
        },
        "active_features": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Active Features"
        },
        "co_tenants": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Co Tenants"
        },
        "is_stressed": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Is Stressed"
        },
        "is_drained": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Is Drained"
        }
      },
      "required": [
        "name"
      ],
      "title": "_NodeSnapshot",
      "type": "object"
    },
    "_ParallelEnvironment": {
      "additionalProperties": false,
      "description": "One scheduler 'parallel environment' — the named pool you target for work.\n\nNormalized across schedulers (#293) so a consumer never branches on\nscheduler_kind: SGE PEs, SLURM partitions, and PBS queues all project onto\nthe SAME core. Scheduler-specific extras live in ``raw`` (whose keys DO vary)\nrather than the core, so the core never lies about uniformity — e.g. SGE's\n``allocation_rule`` and the fuzzy per-scheduler ``slots`` (SGE/SLURM total\ncapacity vs PBS per-job ceiling) are raw, not core.",
      "properties": {
        "name": {
          "description": "What you request: SGE -pe NAME / SLURM -p NAME / PBS -q NAME.",
          "title": "Name",
          "type": "string"
        },
        "source": {
          "description": "Which scheduler concept this is: SGE PE, SLURM partition, or PBS queue.",
          "enum": [
            "pe",
            "partition",
            "queue"
          ],
          "title": "Source",
          "type": "string"
        },
        "kind": {
          "description": "Node-span capability: smp = single-node only, mpi = multi-node capable, other = couldn't be classified (inspect the raw allocation_rule).",
          "enum": [
            "smp",
            "mpi",
            "other"
          ],
          "title": "Kind",
          "type": "string"
        },
        "max_nodes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Max nodes a single job may span here; None = unbounded or unknown.",
          "title": "Max Nodes"
        },
        "raw": {
          "additionalProperties": true,
          "description": "Scheduler-specific detail whose keys vary by source: SGE carries {allocation_rule, slots}, SLURM/PBS carry {slots}. slots' meaning is scheduler-specific (SGE/SLURM total capacity; PBS per-job ncpus ceiling).",
          "title": "Raw",
          "type": "object"
        }
      },
      "required": [
        "name",
        "source",
        "kind"
      ],
      "title": "_ParallelEnvironment",
      "type": "object"
    }
  }
}
