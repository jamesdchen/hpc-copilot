{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/recommend_wait_alternative.output.json",
  "title": "RecommendWaitAlternativeResult",
  "type": "object",
  "required": [
    "rate_priority_per_hour",
    "method",
    "n_samples"
  ],
  "additionalProperties": false,
  "properties": {
    "rate_priority_per_hour": {
      "description": "Fitted climb rate. Zero when ``method=insufficient_data`` or ``method=reset_observed`` (priority went down — caller should treat the rate as untrustworthy).",
      "minimum": 0,
      "title": "Rate Priority Per Hour",
      "type": "number"
    },
    "method": {
      "enum": [
        "linear_regression",
        "two_point",
        "insufficient_data",
        "reset_observed"
      ],
      "title": "Method",
      "type": "string"
    },
    "n_samples": {
      "minimum": 0,
      "title": "N Samples",
      "type": "integer"
    },
    "forecasts": {
      "description": "One entry per requested ``wait_horizons_hours``. Empty when no horizons were requested or the rate is zero.",
      "items": {
        "$ref": "#/$defs/_ForecastEntry"
      },
      "title": "Forecasts",
      "type": "array"
    }
  },
  "$defs": {
    "_ForecastEntry": {
      "additionalProperties": false,
      "description": "Forecast for one wait-horizon.",
      "properties": {
        "wait_hours": {
          "minimum": 0,
          "title": "Wait Hours",
          "type": "number"
        },
        "forecast_priority": {
          "minimum": 0,
          "title": "Forecast Priority",
          "type": "integer"
        }
      },
      "required": [
        "wait_hours",
        "forecast_priority"
      ],
      "title": "_ForecastEntry",
      "type": "object"
    }
  }
}
