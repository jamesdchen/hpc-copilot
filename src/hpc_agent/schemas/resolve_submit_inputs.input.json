          "title": "Run Id",
          "type": "string"
        },
        "cmd_sha": {
          "pattern": "^[0-9a-f]{8,64}$",
          "title": "Cmd Sha",
          "type": "string"
        },
        "executor": {
          "minLength": 1,
          "title": "Executor",
          "type": "string"
        },
        "result_dir_template": {
          "minLength": 1,
          "title": "Result Dir Template",
          "type": "string"
        },
        "task_count": {
