          "title": "Task Count",
          "type": "integer"
        },
        "tasks_py_sha": {
          "default": "",
          "pattern": "^([0-9a-f]{64})?$",
          "title": "Tasks Py Sha",
          "type": "string"
        },
        "wave_map": {
          "anyOf": [
            {
              "additionalProperties": {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
