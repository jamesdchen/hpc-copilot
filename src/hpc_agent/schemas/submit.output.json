{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/submit.output.json",
  "title": "submit output data",
  "description": "Shape of the ``data`` field on a successful ``submit`` envelope.",
  "type": "object",
  "required": [
    "run_id",
    "job_ids",
    "total_tasks",
    "deduped"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "job_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Job Ids",
      "type": "array"
    },
    "total_tasks": {
      "minimum": 1,
      "title": "Total Tasks",
      "type": "integer"
    },
    "deduped": {
      "title": "Deduped",
      "type": "boolean"
    }
  }
}
