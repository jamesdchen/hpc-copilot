"""Shared pytest fixtures for the experiment repo.

Injected once by ``hpc-agent build-template``; project-owned thereafter
(refused, not re-injected, over your edits).

**Fresh-clone hook.** The generated ``src/`` package is ``.gitignore``\\ d
— a clean ``git clone && pytest`` has no ``src/`` yet. This file rebuilds
it (``hpc-agent export-package``) on import, before pytest collects the
tests that import from ``src/``. No manual ``make`` step needed.

**The serial-elision gate is the load-bearing test.** Wire one per
experiment so a misclassified ``DataAxis`` fails CI instead of silently
returning plausible-but-wrong numbers. Drive it from the *classified*
axis recorded in ``.hpc/axes.yaml`` via :func:`data_axis_for` — don't
hard-code the axis::

    from hpc_agent.incorporation.template import assert_elision_equivalent
    from conftest import data_axis_for
    from src.my_experiment import run

    def test_my_experiment_elision() -> None:
        axis = data_axis_for("run")
        assert axis is not None, "run() is unclassified — run /hpc-classify-axis"
        assert_elision_equivalent(run, {}, axis, chunks=4, series_length=...)

If an experiment registers no such test, the gate is simply absent — CI
warns (nothing to check) rather than blocking.

If your experiments call ``hpc_agent.incorporation.template.load_series``, register a
loader once here::

    import pytest
    from hpc_agent.incorporation.template import set_series_loader

    @pytest.fixture(autouse=True)
    def _series_loader() -> None:
        set_series_loader(lambda name: ...)
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path
from typing import Any

_REPO_ROOT = Path(__file__).resolve().parent

# Fresh-clone hook — build src/ before any test imports from it.
if not (_REPO_ROOT / "src").is_dir():
    subprocess.run(  # noqa: S603
        [
            sys.executable,
            "-m",
            "hpc_agent",
            "export-package",
            "--experiment-dir",
            str(_REPO_ROOT),
        ],
        check=False,
    )


def data_axis_for(run_name: str) -> Any:
    """Return the classified ``DataAxis`` for *run_name*, or ``None``.

    Reads ``.hpc/axes.yaml``'s ``executors`` block (written by
    ``/hpc-classify-axis`` / the ``classify-axis`` primitive) and
    rebuilds the live ``DataAxis``. ``None`` means the run was never
    classified — the elision test should assert on that explicitly.
    """
    from hpc_agent.planning.axes import read_executor
    from hpc_agent.incorporation.template import data_axis_from_config

    entry = read_executor(_REPO_ROOT, run_name)
    if entry is None:
        return None
    return data_axis_from_config(entry["data_axis"])
