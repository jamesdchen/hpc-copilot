# hpc-agent experiment-template — make fragment.
#
# Framework-owned: re-injected verbatim by `hpc-agent build-template`
# on every run (self-healing). Do NOT edit — put project-specific
# targets in the root Makefile, below the `include` line.

PYTHON ?= python3

.DEFAULT_GOAL := build
.PHONY: build export repro new-experiment lint test

## build: export every notebook to src/ (content-hash cached; the default goal)
build:
	hpc-agent export-package --experiment-dir .

## export: alias for build — re-export every notebook to src/
export: build

## new-experiment: scaffold a new experiment notebook (make new-experiment NAME=foo)
new-experiment:
	$(PYTHON) .hpc/scaffold.py new $(NAME)

## repro: rebuild src/, then run the test suite (the serial-elision gate lives here)
repro: build test

## lint: rebuild src/, then ruff-check the built package
lint: build
	ruff check src
	ruff format --check src

## test: run the experiment test suite (conftest.py rebuilds src/ if absent)
test:
	pytest -q
