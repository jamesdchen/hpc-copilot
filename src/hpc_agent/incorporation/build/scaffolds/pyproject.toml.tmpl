# Experiment repo — generated by `hpc-agent build-template`.
#
# When build-template runs against a repo that ALREADY has a
# pyproject.toml, this file is written to .hpc/pyproject-fragment.toml
# instead and never merged blind — fold the sections you need in by hand.

[project]
name = "experiments"
version = "0.1.0"
requires-python = ">=3.10"
dependencies = [
    # The hpc_agent.experiment_kit library is a dependency, never vendored.
    "hpc-agent",
]

[dependency-groups]
# `hpc-agent export-package` post-processes every generated src/*.py with
# `ruff format` + `ruff check --fix`. Pin ruff so the build is
# byte-stable — an unpinned ruff would silently churn the build cache and
# any generated-code diff. Bump deliberately, not by surprise.
dev = [
    "ruff==0.13.0",
    "mypy",
    "pytest",
]

[tool.ruff]
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "W", "UP", "B"]

[tool.pytest.ini_options]
addopts = "-ra"
# src/ is generated (conftest.py builds it); tests live under tests/.
testpaths = ["tests"]
