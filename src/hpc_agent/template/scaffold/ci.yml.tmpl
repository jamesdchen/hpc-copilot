# Experiment CI — injected by `hpc-agent build-template`.
#
# The notebook is the reviewed artifact; src/ is generated and
# .gitignore'd. CI builds it first, then runs every gate against the
# *built* output — so a notebook that exports dirty fails here.
#
# Gates, in dependency order: build -> discovery -> lint/type-check ->
# the serial-elision gate + experiment tests.

name: experiments

on:
  push:
  pull_request:

jobs:
  experiments:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - name: Install
        run: pip install -e . || pip install hpc-agent
      - name: Build — export notebooks to src/
        run: hpc-agent export-package --experiment-dir .
      - name: Discovery — every notebook exposes a @register_run
        run: python .hpc/scaffold.py discover
      - name: Lint + type-check the built package
        run: |
          ruff check src
          ruff format --check src
          mypy --ignore-missing-imports src
      - name: Serial-elision gate + experiment tests
        run: pytest -q
