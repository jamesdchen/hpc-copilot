# Experiment repo — generated by `hpc-agent build-template`.
#
# When build-template runs against a repo that ALREADY has a
# pyproject.toml, this file is written to .hpc/pyproject-fragment.toml
# instead and never merged blind — fold the sections you need in by hand.

[project]
name = "experiments"
version = "0.1.0"
requires-python = ">=3.10"
dependencies = [
    # The hpc_agent.template library is a dependency, never vendored.
    "hpc-agent",
]

[tool.ruff]
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "W", "UP", "B"]

[tool.pytest.ini_options]
addopts = "-ra"
testpaths = ["experiments", "tests"]
