{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/validate.output.json",
  "title": "validate output (data block)",
  "description": "Data block from ``hpc-agent validate``.\n\nWraps the scheduler's --test-only response into a structured\ntiming prediction.",
  "type": "object",
  "required": [
    "profile",
    "cluster",
    "scheduler",
    "estimated_start_iso",
    "predicted_eta_sec",
    "fits_backfill",
    "backfill_window_sec",
    "reason",
    "scheduler_response"
  ],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "title": "Profile",
      "type": "string"
    },
    "cluster": {
      "title": "Cluster",
      "type": "string"
    },
    "scheduler": {
      "enum": [
        "sge",
        "slurm"
      ],
      "title": "Scheduler",
      "type": "string"
    },
    "estimated_start_iso": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "description": "ISO-8601 UTC timestamp when scheduler predicts start.",
      "title": "Estimated Start Iso"
    },
    "predicted_eta_sec": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "description": "Seconds from now until predicted start. None when the probe was unparseable or the scheduler is non-SLURM.",
      "title": "Predicted Eta Sec"
    },
    "fits_backfill": {
      "title": "Fits Backfill",
      "type": "boolean"
    },
    "backfill_window_sec": {
      "minimum": 1,
      "title": "Backfill Window Sec",
      "type": "integer"
    },
    "reason": {
      "title": "Reason",
      "type": "string"
    },
    "scheduler_response": {
      "description": "Raw probe stdout/stderr (clamped to 2000 chars).",
      "title": "Scheduler Response",
      "type": "string"
    }
  }
}
