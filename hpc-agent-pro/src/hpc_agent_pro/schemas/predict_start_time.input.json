{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/hpc-agent/schemas/predict_start_time.input.json",
  "title": "PredictStartTimeSpec",
  "type": "object",
  "required": [
    "now_iso",
    "squeue_text",
    "partition",
    "partition_slot_count",
    "your_priority",
    "your_walltime_sec"
  ],
  "additionalProperties": false,
  "properties": {
    "now_iso": {
      "description": "ISO timestamp anchoring the forecast.",
      "minLength": 1,
      "title": "Now Iso",
      "type": "string"
    },
    "squeue_text": {
      "description": "Raw output of ``squeue --user='*' -O 'JOBID|PRIORITY|PARTITION|USERNAME|STATE|TIME_LEFT|TIME_LIMIT'``.",
      "title": "Squeue Text",
      "type": "string"
    },
    "partition": {
      "minLength": 1,
      "title": "Partition",
      "type": "string"
    },
    "partition_slot_count": {
      "minimum": 1,
      "title": "Partition Slot Count",
      "type": "integer"
    },
    "your_priority": {
      "minimum": 0,
      "title": "Your Priority",
      "type": "integer"
    },
    "your_walltime_sec": {
      "minimum": 1,
      "title": "Your Walltime Sec",
      "type": "integer"
    },
    "your_user": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Your User"
    },
    "your_constraint": {
      "default": "",
      "title": "Your Constraint",
      "type": "string"
    },
    "pending_walltime_default_sec": {
      "default": 86400,
      "minimum": 1,
      "title": "Pending Walltime Default Sec",
      "type": "integer"
    },
    "sshare_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Raw ``sshare -P`` output. When absent, fairshare features collapse to sentinels.",
      "title": "Sshare Text"
    },
    "candidate_offsets_hours": {
      "description": "Offsets to evaluate for the wait-vs-submit-now sweep. The primitive picks whichever offset minimizes total time-to-actual-start.",
      "items": {
        "type": "number"
      },
      "title": "Candidate Offsets Hours",
      "type": "array"
    },
    "model_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Path to a serialized LightGBM ``model.txt``. When absent, predictions fall back to the pessimistic floor (no residual).",
      "title": "Model Path"
    }
  }
}
