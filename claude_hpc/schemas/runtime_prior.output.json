{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/runtime_prior.output.json",
  "title": "runtime-prior output data",
  "description": "Shape of the `data` field on a successful `runtime-prior --profile <p> --cluster <c>` envelope.",
  "type": "object",
  "required": ["profile", "cluster", "now_iso", "needs_canary", "quantiles", "total_samples"],
  "additionalProperties": false,
  "properties": {
    "profile":              { "type": "string" },
    "cluster":              { "type": "string" },
    "now_iso":              { "type": "string" },
    "needs_canary":         {
      "type": "boolean",
      "description": "True when no samples exist for this (profile, cluster) pair. Caller should submit a 1-task canary, ingest its result via runtime_prior.append_sample, then re-call."
    },
    "quantiles": {
      "type": "object",
      "description": "Per-gpu_type runtime quantile rollup. Empty dict when needs_canary is true.",
      "additionalProperties": {
        "type": "object",
        "required": ["p50", "p95", "n_samples"],
        "properties": {
          "p50":         { "type": "number", "minimum": 0 },
          "p95":         { "type": "number", "minimum": 0 },
          "p99":         { "type": "number", "minimum": 0 },
          "mean_sec":    { "type": "number", "minimum": 0 },
          "n_samples":   { "type": "integer", "minimum": 0 },
          "min_sec":     { "type": "number", "minimum": 0 },
          "max_sec":     { "type": "number", "minimum": 0 }
        }
      }
    },
    "total_samples":        { "type": "integer", "minimum": 0 },
    "filtered_by_cmd_sha":  { "type": ["string", "null"] }
  }
}
