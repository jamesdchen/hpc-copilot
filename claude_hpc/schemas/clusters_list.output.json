{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/clusters_list.output.json",
  "title": "clusters list output data",
  "description": "Shape of the `data` field on a successful `clusters list` envelope.",
  "type": "object",
  "required": ["clusters"],
  "additionalProperties": false,
  "properties": {
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "host", "scheduler"],
        "properties": {
          "name":      { "type": "string" },
          "host":      { "type": "string" },
          "scheduler": { "type": "string", "enum": ["sge", "slurm"] }
        }
      }
    }
  }
}
