{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/capabilities.output.json",
  "title": "capabilities output data",
  "type": "object",
  "required": [
    "version", "subcommands", "supported_schedulers",
    "schemas_dir", "journal_dir", "ssh_multiplexing",
    "mars_skill_paths", "required_env"
  ],
  "additionalProperties": false,
  "properties": {
    "version":             { "type": "string" },
    "subcommands":         { "type": "array", "items": { "type": "string" } },
    "supported_schedulers":{ "type": "array", "items": { "type": "string", "enum": ["sge", "slurm"] } },
    "schemas_dir":         { "type": "string" },
    "journal_dir":         { "type": "string" },
    "ssh_multiplexing":    { "type": "boolean" },
    "mars_skill_paths": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "required_env": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cluster_yaml_keys": {
      "type": "array",
      "description": "Declarative manifest of per-cluster fields recognized in clusters.yaml. Lets a campus user discover the schema by inspection without reading claude_hpc/infra/clusters.py source. Each item describes one validated field.",
      "items": {
        "type": "object",
        "required": ["key", "type", "required", "description"],
        "additionalProperties": true,
        "properties": {
          "key":         { "type": "string" },
          "type":        { "type": "string" },
          "required":    { "type": "boolean" },
          "default":     {},
          "description": { "type": "string" }
        }
      }
    },
    "operations": {
      "type": "array",
      "description": "Per-operation catalog. The CLI subcommands listed in `subcommands` are the invocable surface; this `operations` block carries machine-readable metadata about each one (verb tier, idempotency, side-effect class, schema files). Source-tree installs read from docs/primitives/ frontmatter; future wheel installs will read a baked operations.json shipped in the package.",
      "items": {
        "type": "object",
        "required": ["name", "verb", "idempotent", "side_effects"],
        "additionalProperties": false,
        "properties": {
          "name":          { "type": "string" },
          "verb":          { "type": "string", "enum": ["query", "validate", "mutate", "submit", "scaffold", "workflow"] },
          "idempotent":    { "type": "boolean" },
          "side_effects":  { "type": "array", "items": { "type": "string" } },
          "cli":           { "type": ["string", "null"] },
          "python":        { "type": ["string", "null"] },
          "input_schema":  { "type": ["string", "null"] },
          "output_schema": { "type": ["string", "null"] }
        }
      }
    }
  }
}
