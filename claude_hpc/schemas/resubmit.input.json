{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/resubmit.input.json",
  "title": "resubmit input spec",
  "type": "object",
  "required": ["failed_task_ids", "category"],
  "additionalProperties": false,
  "properties": {
    "failed_task_ids": { "type": "array", "items": { "type": "integer", "minimum": 0 }, "minItems": 1 },
    "category": {
      "type": "string",
      "description": "Must match claude_hpc.mapreduce.reduce.classify.CATEGORIES exactly.",
      "enum": [
        "gpu_oom", "system_oom", "segv", "walltime", "node_failure",
        "queue_stall", "code_bug", "unknown", "preempted"
      ]
    },
    "overrides":   { "type": "object", "description": "Resource overrides for retry (mem, walltime, gpus, ...)." },
    "new_job_ids": { "type": ["array", "null"], "items": { "type": "string" } },
    "request_id": {
      "type": ["string", "null"],
      "description": "Optional dedupe key. When omitted, claude-hpc derives a deterministic id from (sorted failed_task_ids, category, sorted overrides). A second resubmit with the same request_id returns the existing record without incrementing retry counters."
    }
  }
}
