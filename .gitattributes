# Normalize all text files to LF on commit; check out with native EOL.
# Prevents CRLF from Windows checkouts breaking shell scripts executed on Linux clusters.
* text=auto eol=lf

# Scripts executed on remote Linux clusters — MUST be LF or shebang breaks.
*.sh    text eol=lf
*.slurm text eol=lf
*.py    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files (explicit to avoid accidental normalization)
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.gz   binary
*.zip  binary

# --------------------------------------------------------------------------- #
# Generated-artifact keep-ours merge driver (scripts/merge_generated.py)
# --------------------------------------------------------------------------- #
# These files are a PURE FUNCTION of the primitive registry — regenerated in
# FULL by the regen scripts. They are the dominant swarm merge-conflict class.
# The `generated` driver keeps OURS on a both-sides-changed merge; a post-merge
# `scripts/regen_all.py --write` then rebuilds them from the merged registry.
# The driver is NOT built into git — deploy it per clone with
# `python scripts/merge_generated.py ensure` (WS1's regen_all runs this at the
# top of every regen; worktrees share the clone's config, so one ensure covers
# them all). A clone that never ran ensure degrades LOUDLY to a normal conflict.
# Applies to `git merge` AND `git rebase`/`cherry-pick` — but rebase inverts
# ours/theirs, so a rebasing branch drops its OWN generated edits until the
# post-rebase regen restores them. The set below is mirrored by
# scripts/merge_generated.py::FULLY_GENERATED_PATTERNS and pinned in lockstep by
# tests/contracts/test_generated_merge_driver.py.
docs/generated/**                      merge=generated
src/hpc_agent/cli/_verb_module_map.py  merge=generated
src/hpc_agent/operations.json          merge=generated
src/hpc_agent/schemas/*.json           merge=generated

# Hand-authored composite/preflight operation schemas: build_schemas.py does
# NOT emit these, so keep-ours would silently drop edits no regen script
# restores. Reset them to git's default 3-way text merge. Mirrored by
# scripts/merge_generated.py::SCHEMA_MERGE_UNSET; pinned equal to
# (live top-level schemas − build_schemas emitted) by the contract test, so a
# new hand-authored schema turns the pin RED rather than being silently swept in.
src/hpc_agent/schemas/aggregate_preflight.input.json          !merge
src/hpc_agent/schemas/aggregate_preflight.output.json         !merge
