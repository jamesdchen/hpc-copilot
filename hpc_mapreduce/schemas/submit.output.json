{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/submit.output.json",
  "title": "submit output data",
  "description": "Shape of the `data` field on a successful `submit` envelope.",
  "type": "object",
  "required": ["run_id", "job_ids", "total_tasks", "deduped"],
  "additionalProperties": false,
  "properties": {
    "run_id":      { "type": "string", "pattern": "^[A-Za-z0-9._\\-]+$" },
    "job_ids":     { "type": "array", "items": { "type": "string" } },
    "total_tasks": { "type": "integer", "minimum": 0 },
    "deduped":     { "type": "boolean" }
  }
}
