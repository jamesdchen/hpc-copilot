{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/best_submit_window.input.json",
  "title": "best-submit-window input",
  "description": "Inputs for the `best-submit-window` primitive (hpc-mapreduce best-submit-window --profile <p> --cluster <c>).",
  "type": "object",
  "required": ["profile", "cluster"],
  "additionalProperties": false,
  "properties": {
    "profile":      { "type": "string" },
    "cluster":      { "type": "string" },
    "within_hours": { "type": "integer", "minimum": 1, "default": 24 },
    "top_k":        { "type": "integer", "minimum": 1, "default": 5 }
  }
}
