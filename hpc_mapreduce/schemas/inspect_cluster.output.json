{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/inspect_cluster.output.json",
  "title": "inspect-cluster output data",
  "description": "Shape of the `data` field on a successful `inspect-cluster --cluster <name>` envelope.",
  "type": "object",
  "required": ["cluster", "scheduler_kind", "now_iso", "nodes", "errors"],
  "additionalProperties": false,
  "properties": {
    "cluster":        { "type": "string" },
    "scheduler_kind": { "type": "string", "enum": ["sge", "slurm"] },
    "now_iso":        { "type": "string", "description": "UTC ISO-8601 timestamp of the snapshot." },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": true,
        "properties": {
          "name":             { "type": "string" },
          "alloc_mem_pct":    { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "cpu_load_frac":    { "type": ["number", "null"], "minimum": 0 },
          "gres":             { "type": ["string", "null"] },
          "gres_used":        { "type": ["string", "null"] },
          "active_features":  { "type": "array", "items": { "type": "string" } },
          "co_tenants":       {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true },
            "description": "Other jobs sharing the node. Shape varies per scheduler."
          },
          "is_stressed":      { "type": "boolean" },
          "is_drained":       { "type": "boolean" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal per-node errors (e.g. one node failed to report). Fatal cases raise ssh_unreachable instead."
    }
  }
}
