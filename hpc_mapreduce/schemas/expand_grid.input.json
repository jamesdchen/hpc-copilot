{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/expand_grid.input.json",
  "title": "expand-grid input spec",
  "type": "object",
  "required": ["grid"],
  "properties": {
    "grid": {
      "type": "object",
      "description": "Map of grid axis name → list of values (Cartesian product).",
      "additionalProperties": {
        "type": "array",
        "items": { "type": ["string", "number", "integer", "boolean"] },
        "minItems": 1
      }
    }
  }
}
