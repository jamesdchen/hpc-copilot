{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/discover.output.json",
  "title": "discover output data",
  "type": "object",
  "required": ["executors"],
  "additionalProperties": false,
  "properties": {
    "executors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "cli_framework", "has_main_guard"],
        "additionalProperties": false,
        "properties": {
          "name":           { "type": "string" },
          "path":           { "type": "string" },
          "cli_framework":  { "type": ["string", "null"] },
          "has_main_guard": { "type": "boolean" }
        }
      }
    },
    "meta": {
      "description": "MARs experiment context, extracted from meta.json. Present only when meta.json exists at the experiment-dir root.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "experiment_id": { "type": "string" },
        "seed":          { "type": ["integer", "number"] },
        "purpose":       { "type": "string" },
        "tier":          { "type": ["integer", "null"], "enum": [1, 2, null] }
      }
    }
  }
}
