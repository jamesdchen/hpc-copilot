{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jamesdchen/claude-hpc/schemas/validate.output.json",
  "title": "validate output (data block)",
  "description": "Data block from `hpc-mapreduce validate`. Wraps the scheduler's --test-only response into a structured timing prediction.",
  "type": "object",
  "required": [
    "profile",
    "cluster",
    "scheduler",
    "estimated_start_iso",
    "predicted_eta_sec",
    "fits_backfill",
    "backfill_window_sec",
    "reason",
    "scheduler_response"
  ],
  "additionalProperties": false,
  "properties": {
    "profile": {
      "type": "string"
    },
    "cluster": {
      "type": "string"
    },
    "scheduler": {
      "type": "string"
    },
    "estimated_start_iso": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO-8601 UTC timestamp when scheduler predicts start."
    },
    "predicted_eta_sec": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "Seconds from now until predicted start. None when the probe was unparseable or the scheduler is non-SLURM."
    },
    "fits_backfill": {
      "type": "boolean"
    },
    "backfill_window_sec": {
      "type": "integer",
      "minimum": 1
    },
    "reason": {
      "type": "string"
    },
    "scheduler_response": {
      "type": "string",
      "description": "Raw probe stdout/stderr (clamped to 2000 chars)."
    }
  }
}
